      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "title": "Recommendation Requests / min",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(recsys_recommendation_requests_total[1m])) * 60",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "title": "API P95 Latency (s)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(recsys_request_latency_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "title": "Events Generated / min",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(recsys_events_generated_total[1m])) by (event_type) * 60",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "title": "Events Consumed / min",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(recsys_events_consumed_total[1m])) by (event_type) * 60",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 5,
      "title": "Candidates Merged",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(recsys_candidates_generated_sum[5m]) / rate(recsys_candidates_generated_count[5m])",
          "refId": "A"
